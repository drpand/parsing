# ============================================================================
# IndiaShop Bot v1.2.0 — Environment Configuration
# © 2026 IndiaShop. All Rights Reserved.
#
# ИНСТРУКЦИЯ ПО ЗАПОЛНЕНИЮ:
# 1. Скопируйте этот файл как .env
# 2. Заполните значения ниже (без кавычек)
# 3. Сохраните файл
# ============================================================================

# ----------------------------------------------------------------------------
# TELEGRAM BOT
# ----------------------------------------------------------------------------
# Токен бота от @BotFather (Telegram)
# Пример: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=your_token_here

# Telegram ID администраторов (через запятую)
# Как получить: напишите @userinfobot в Telegram
# Пример: 123456789,987654321
ADMIN_TELEGRAM_IDS=your_telegram_id_here

# Username менеджеров (через запятую, без @)
# Пример: manager1,manager2
MANAGER_USERNAMES=your_username_here

# Интервал автопостинга (в минутах)
POST_INTERVAL_MINUTES=60

# ----------------------------------------------------------------------------
# OPENROUTER AI
# ----------------------------------------------------------------------------
# API ключ от https://openrouter.ai/keys
# Пример: sk-or-v1-abcdef123456789...
OPENROUTER_API_KEY=your_api_key_here

# Модель AI (рекомендуется)
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Резервные модели (через запятую)
OPENROUTER_FALLBACK_MODELS=qwen/qwen3.5-27b

# Таймаут запросов к AI (секунды)
OPENROUTER_TIMEOUT=30

# ----------------------------------------------------------------------------
# GITHUB (опционально, для интеграции)
# ----------------------------------------------------------------------------
# Токен от https://github.com/settings/tokens
# Scope: repo
GITHUB_TOKEN=your_github_token_here

# ----------------------------------------------------------------------------
# DATABASE (SQLite)
# ----------------------------------------------------------------------------
# Путь к базе данных (не менять)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# ----------------------------------------------------------------------------
# PRICING (цены и наценки)
# ----------------------------------------------------------------------------
# Курс USD → INR (индийская рупия)
USD_INR=92.0

# Курс USD → RUB (российский рубль)
USD_RUB=88.0

# Наценка (%)
MARGIN_PERCENT=25.0

# Фиксированная стоимость доставки (₽)
DELIVERY_FIXED=500

# Процент доставки от стоимости (%)
DELIVERY_PERCENT=5.0

# ----------------------------------------------------------------------------
# DEBUG (отладка)
# ----------------------------------------------------------------------------
# Режим отладки (True/False)
DEBUG=False

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
