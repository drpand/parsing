from aiogram import Router, F
from aiogram.types import Message, CallbackQuery, InlineKeyboardButton, BufferedInputFile
from aiogram.utils.keyboard import InlineKeyboardBuilder
from aiogram.fsm.context import FSMContext
from sqlalchemy import select, func
from app.core.config import settings
from app.db.database import database
from app.db.models import Product
from app.utils.logger import logger
from app.utils.helpers import safe_html, truncate_text
from app.bots.handlers.admin_settings import get_setting_value
from app.bots.handlers.admin_menu import AdminStates
from aiogram.fsm.state import State, StatesGroup

# 🔐 ДОПОЛНИТЕЛЬНЫЕ СОСТОЯНИЯ ДЛЯ РЕДАКТИРОВАНИЯ
class ProductEditStates(StatesGroup):
    waiting_for_title = State()
    waiting_for_price = State()
    waiting_for_description = State()
    waiting_for_in_stock = State()
    waiting_for_delete_confirm = State()
    waiting_for_edit_action = State()
import json
import requests

router = Router()

ITEMS_PER_PAGE = 10  # 🔐 10 ТОВАРОВ НА СТРАНИЦЕ


# ===== ОБРАБОТКА КНОПКИ "📦 Товары" (ТЕКСТ) =====

@router.message(F.text == "📦 Товары")
async def admin_products_text(message: Message, state: FSMContext):
    """
    📦 Обработка кнопки "Товары" из главного меню
    ✅ ПРОВЕРКА: Пустая база, ошибки БД, логирование
    ✅ ДОСТУП: Админы и Менеджеры
    """
    await state.clear()  # 🔐 ПРИНУДИТЕЛЬНЫЙ СБРОС ЛЮБОГО СОСТОЯНИЯ

    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    user_id = message.from_user.id
    is_admin = user_id in settings.admin_ids
    is_manager = False
    if not is_admin:
        from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(user_id) for m in managers)

    if not is_admin and not is_manager:
        return

    logger.info(f"{'Manager' if is_manager else 'Admin'} {user_id} clicked 'Товары' button")

    try:
        async with database.get_session() as session:
            # 🔐 ПРОВЕРКА: Есть ли товары вообще
            total = (await session.execute(select(func.count(Product.id)))).scalar() or 0

            if total == 0:
                await message.answer(
                    "📭 <b>База товаров пуста!</b>\n\n"
                    "Сначала запустите парсинг:\n"
                    "1. Нажмите 🔍 Парсинг категории\n"
                    "2. Выберите товар или категорию\n"
                    "3. После парсинга товары появятся здесь",
                    parse_mode="HTML",
                )
                logger.info(f"Admin {message.from_user.id} tried to view products, but DB is empty")
                return

            # 🔐 ВСЁ ОК — показываем товары
            await show_products_page(message, state, page=1)

    except Exception as e:
        logger.error(f"❌ Ошибка при просмотре товаров: {type(e).__name__}: {e}", exc_info=True)
        await message.answer(
            "❌ <b>Ошибка при загрузке товаров!</b>\n\n"
            f"<i>{safe_html(str(e)[:200])}</i>\n\n"
            "Попробуйте позже или проверьте логи.",
            parse_mode="HTML",
        )


async def show_products_page(callback: CallbackQuery | Message, state: FSMContext, page: int = 1):
    """
    🔐 Показывает страницу товаров (10 штук)
    ✅ БЕЗ ТЕКСТА — ТОЛЬКО КНОПКИ!
    ✅ ДОСТУП: Админы и Менеджеры
    """
    await state.clear()

    user_id = callback.from_user.id if hasattr(callback, 'from_user') else callback.from_user.id

    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    is_admin = user_id in settings.admin_ids
    is_manager = False
    if not is_admin:
        from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(user_id) for m in managers)

    if not is_admin and not is_manager:
        return

    logger.info(f"{'Manager' if is_manager else 'Admin'} {user_id} viewing products page {page}")

    try:
        async with database.get_session() as session:
            # Считаем товары
            total = (await session.execute(select(func.count(Product.id)))).scalar() or 0
            active = (await session.execute(
                select(func.count(Product.id)).where(Product.is_active == True)
            )).scalar() or 0

            total_pages = max(1, (total + ITEMS_PER_PAGE - 1) // ITEMS_PER_PAGE)
            page = max(1, min(page, total_pages))  # Ограничиваем страницу

            # Получаем товары для текущей страницы
            offset = (page - 1) * ITEMS_PER_PAGE
            result = await session.execute(
                select(Product)
                .order_by(Product.created_at.desc())
                .offset(offset)
                .limit(ITEMS_PER_PAGE)
            )
            products = result.scalars().all()

            # 🔐 ТЕКСТ — ЗАГОЛОВОК С КОЛИЧЕСТВОМ!
            text = f"📦 Товары: {total}"  # Заголовок с количеством

            if total == 0:
                # 🔐 БАЗА ПУСТА — показываем сообщение
                text = "📭 База товаров пуста!"

                keyboard = InlineKeyboardBuilder()
                keyboard.button(text="🔙 В админ-панель", callback_data="admin_back")

                if isinstance(callback, CallbackQuery):
                    try:
                        await callback.message.edit_text(text, reply_markup=keyboard.as_markup(), parse_mode="HTML")
                    except Exception:
                        await callback.message.answer(text, reply_markup=keyboard.as_markup(), parse_mode="HTML")
                else:
                    await callback.answer(text, reply_markup=keyboard.as_markup(), parse_mode="HTML")

                logger.info(f"Admin {user_id} viewed products, but DB is empty")
                return

            if not products:
                text += "❌ Товаров нет\n"

            # Создаём inline клавиатуру
            keyboard = InlineKeyboardBuilder()

            # 🔐 КНОПКИ ТОВАРОВ (строго по одной в ряд)
            for i, product in enumerate(products, 1):
                # Полное название + цена (ровно)
                title = product.title[:45]  # Ограничиваем длину
                price = f"{product.price_rub:,.0f}₽"
                button_text = f"{title} | {price}"
                keyboard.row(  # 🔐 КАЖДАЯ КНОПКА В ОТДЕЛЬНОМ РЯДУ!
                    InlineKeyboardButton(
                        text=button_text,
                        callback_data=f"product_view:{product.id}"
                    )
                )

            # 🔐 ПАГИНАЦИЯ (отдельный ряд)
            nav_buttons = []
            if page > 1:
                nav_buttons.append(InlineKeyboardButton(text="◀️", callback_data=f"products_page:{page-1}"))

            nav_buttons.append(InlineKeyboardButton(text=f"{page}/{total_pages}", callback_data="empty"))

            if page < total_pages:
                nav_buttons.append(InlineKeyboardButton(text="▶️", callback_data=f"products_page:{page+1}"))

            if nav_buttons:
                keyboard.row(*nav_buttons)

            # 🔐 КНОПКА "В АДМИНКУ" (отдельно)
            keyboard.row(InlineKeyboardButton(text="🔙 В админ-панель", callback_data="admin_back"))

            # 🔐 ОТПРАВЛЯЕМ — ТОЛЬКО КНОПКИ!
            if isinstance(callback, CallbackQuery):
                try:
                    await callback.message.edit_text(text, reply_markup=keyboard.as_markup())
                except Exception as e:
                    logger.error(f"Error editing message: {e}")
                    # Если нельзя редактировать — удаляем старое и отправляем новое
                    try:
                        await callback.message.delete()
                    except Exception:
                        pass
                    await callback.message.answer(text, reply_markup=keyboard.as_markup())
            else:
                await callback.answer(text, reply_markup=keyboard.as_markup())

    except Exception as e:
        logger.error(f"Products list error: {e}")
        error_text = f"❌ Ошибка\n\n{str(e)[:200]}"
        if isinstance(callback, CallbackQuery):
            await callback.message.answer(error_text, parse_mode="HTML")
        else:
            await callback.answer(error_text, parse_mode="HTML")


# ===== ПРОСМОТР ТОВАРА =====

@router.callback_query(F.data.startswith("product_view:"))
async def product_view(callback: CallbackQuery, state: FSMContext):
    """
    👁️ Просмотр товара с расчётом цены через USD
    ✅ Цена в рублях через курс USD→INR и USD→RUB
    ✅ СТРЕЛКИ ← → для навигации между товарами
    ✅ ДОСТУП: Админы и Менеджеры
    """
    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    user_id = callback.from_user.id
    is_admin = user_id in settings.admin_ids
    is_manager = False
    if not is_admin:
                from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(user_id) for m in managers)

    if not is_admin and not is_manager:
        return

    try:
        product_id = int(callback.data.split(":")[1])
        logger.info(f"🔐 {'Manager' if is_manager else 'Admin'} {user_id} viewing product: {product_id}")

        async with database.get_session() as session:
            # 🔐 ИЩЕМ ТОВАР ПО ID (а не по индексу!)
            result = await session.execute(
                select(Product).where(Product.id == product_id)
            )
            product = result.scalar()

            if not product:
                await callback.answer("❌ Товар не найден", show_alert=True)
                return

            # 🔐 ПОЛУЧАЕМ КУРСЫ ИЗ БД
            usd_inr = await get_setting_value("usd_inr", 91.0)
            usd_rub = await get_setting_value("usd_rub", 80.0)

            # 🔐 РАСЧЁТ ЦЕНЫ: INR → USD → RUB
            price_usd = product.price_inr / usd_inr  # Конвертируем в USD
            price_rub = int(price_usd * usd_rub)  # Конвертируем в RUB

            # 🔐 НАВИГАЦИЯ: получаем ID предыдущего и следующего товара
            # Получаем все ID товаров в порядке создания (новые первыми)
            all_ids_result = await session.execute(
                select(Product.id).order_by(Product.created_at.desc())
            )
            all_ids = [row[0] for row in all_ids_result.all()]

            try:
                current_index = all_ids.index(product_id)
            except ValueError:
                current_index = -1

            # 🔐 ИСПРАВЛЕНО: prev_id = предыдущий (старее), next_id = следующий (новее)
            # all_ids отсортированы по убыванию (новые первыми)
            prev_id = all_ids[current_index + 1] if current_index >= 0 and current_index + 1 < len(all_ids) else None  # Старее
            next_id = all_ids[current_index - 1] if current_index > 0 else None  # Новее

            # Сохраняем текущую страницу в state
            data = await state.get_data()
            current_page = data.get("products_page", 1)

            # Формируем карточку товара
            text = f"🛍 <b>{product.title[:100]}</b>\n\n"

            # Цены
            if product.original_price_inr and product.discount_percent > 0:
                text += f"🔥 <b>СКИДКА {int(product.discount_percent)}%</b>\n"
                text += f"<s>₹{product.original_price_inr:,.0f}</s> → <b>₹{product.price_inr:,.0f}</b>\n"
                text += f"<b>💰 Цена: {price_rub:,} ₽</b>\n\n"
            else:
                text += f"<b>💰 Цена: {price_rub:,} ₽</b>\n\n"

            # Наличие
            text += f"{'✅' if product.in_stock else '❌'} В наличии\n\n"

            # 🔐 СТАТУС ПУБЛИКАЦИИ С ДАТОЙ
            if product.is_active:
                if product.last_posted_at:
                    # 🔐 Конвертируем UTC в IST (India = UTC+5:30)
                    from datetime import timedelta
                    local_time = product.last_posted_at + timedelta(hours=5, minutes=30)
                    date_str = local_time.strftime("%d.%m.%Y %H:%M")
                    text += f"📊 <b>Опубликован:</b> {date_str} (IST)\n\n"
                else:
                    text += f"📊 <b>Опубликован:</b> Дата не указана\n\n"
            else:
                text += f"📊 <b>Не опубликован</b>\n\n"

            # Картинки
            if product.images:
                images = json.loads(product.images) if isinstance(product.images, str) else product.images
                if images:
                    text += f"🖼 <a href='{images[0]}'>Фото товара</a>\n\n"

            # Ссылка
            if product.source_url:
                text += f"🔗 <a href='{product.source_url}'>Оригинал</a>\n\n"

            text += f"<b>🆔 ID:</b> <code>{product.id}</code>"
            text += f"\n\n<b>📊 Позиция:</b> {current_index + 1} из {len(all_ids)}"

            # 🔐 КНОПКИ ДЕЙСТВИЙ + СТРЕЛКИ
            keyboard = InlineKeyboardBuilder()

            # 🔐 СТРЕЛКИ НАВИГАЦИИ (первый ряд)
            nav_buttons = []
            if prev_id:
                nav_buttons.append(InlineKeyboardButton(text="◀️", callback_data=f"product_view:{prev_id}"))
            else:
                nav_buttons.append(InlineKeyboardButton(text="⚪", callback_data="empty"))

            nav_buttons.append(InlineKeyboardButton(text="🔙 К списку", callback_data="products_view"))

            if next_id:
                nav_buttons.append(InlineKeyboardButton(text="▶️", callback_data=f"product_view:{next_id}"))
            else:
                nav_buttons.append(InlineKeyboardButton(text="⚪", callback_data="empty"))

            keyboard.row(*nav_buttons)

            # Кнопки действий
            keyboard.row(
                InlineKeyboardButton(text="📤 Опубликовать", callback_data=f"product_publish:{product.id}")
            )

            keyboard.row(
                InlineKeyboardButton(text="✏️ Редактировать", callback_data=f"product_edit:{product.id}")
            )

            # Пробуем отправить с фото
            try:
                if product.images:
                    images = json.loads(product.images) if isinstance(product.images, str) else product.images
                    if images and images[0].startswith('http'):
                        response = requests.get(images[0], timeout=10)
                        if response.status_code == 200:
                            photo = BufferedInputFile(response.content, filename=f"product_{product.id}.jpg")
                            await callback.message.answer_photo(
                                photo=photo,
                                caption=text,
                                reply_markup=keyboard.as_markup(),
                                parse_mode="HTML",
                            )
                            return
            except Exception as e:
                logger.warning(f"Failed to send photo: {e}")

            # Если фото не удалось — отправляем текст
            await callback.message.answer(text, reply_markup=keyboard.as_markup(), parse_mode="HTML")

    except Exception as e:
        logger.error(f"Product view error: {e}")
        await callback.answer(f"❌ Ошибка: {str(e)[:100]}", show_alert=True)


# ===== ХЭНДЛЕР "🔙 К СПИСКУ ТОВАРОВ" =====

@router.callback_query(F.data == "products_view")
async def products_view_callback(callback: CallbackQuery, state: FSMContext):
    """
    🔙 Возврат к списку товаров (страница 1)
    """
    await callback.answer()
    # Очищаем страницу при возврате
    await state.update_data(products_page=1)
    await show_products_page(callback, state, page=1)


# ===== ПАГИНАЦИЯ =====

@router.callback_query(F.data.startswith("products_page:"))
async def products_page(callback: CallbackQuery, state: FSMContext):
    """
    📄 Переключение страницы товаров
    ✅ ИЗМЕНЕНО: edit_text + 5 товаров на странице
    """
    if callback.from_user.id not in settings.admin_ids:
        return

    page = int(callback.data.split(":")[1])
    await callback.answer()
    # Сохраняем страницу в state
    await state.update_data(products_page=page)
    await show_products_page(callback, state, page=page)


