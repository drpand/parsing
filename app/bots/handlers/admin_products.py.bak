@router.callback_query(F.data.startswith("product_publish:"))
async def product_publish_now(callback: CallbackQuery):
    """
    📤 Опубликовать товар прямо сейчас
    ✅ Публикация в группу по умолчанию
    ✅ Доступно админам и менеджерам
    """
    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    is_admin = callback.from_user.id in settings.admin_ids

    # Проверяем менеджеров
    is_manager = False
    if not is_admin:
                from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(callback.from_user.id) for m in managers)

    if not is_admin and not is_manager:
        return

    product_id = int(callback.data.split(":")[1])

    try:
        async with database.get_session() as session:
            # 1. Получить товар из БД
            result = await session.execute(select(Product).where(Product.id == product_id))
            product = result.scalar()

            if not product:
                await callback.answer("❌ Товар не найден!", show_alert=True)
                return

            # 2. Получить глобальный poster_service
            from app.services.poster_service import poster_service

            if not poster_service:
                await callback.answer("❌ Сервис публикации не инициализирован!", show_alert=True)
                logger.error("Poster service is None")
                return

            # 3. Получить активные группы
            from app.db.models import PostGroup
            groups_result = await session.execute(
                select(PostGroup).where(PostGroup.is_active == True)
            )
            groups = groups_result.scalars().all()

            if not groups:
                await callback.answer("❌ Нет активных групп для публикации!", show_alert=True)
                logger.warning(f"No active groups for publishing product {product_id}")
                return

            # 4. Опубликовать в первую активную группу
            group = groups[0]
            success = await poster_service._send_post(group, product)

            if success:
                # 5. Записать дату публикации
                from datetime import datetime
                product.last_posted_at = datetime.utcnow()
                product.is_active = True
                await session.commit()

                await callback.answer(f"✅ Товар опубликован в {group.chat_name}!", show_alert=True)
                logger.info(f"Admin {callback.from_user.id} published product {product_id} to {group.chat_name}")
            else:
                await callback.answer("❌ Не удалось опубликовать товар", show_alert=True)
                logger.error(f"Failed to publish product {product_id}")

    except Exception as e:
        logger.error(f"Publish error: {e}", exc_info=True)
        await callback.answer(f"❌ Ошибка: {str(e)[:100]}", show_alert=True)


# ===== РЕДАКТИРОВАНИЕ ТОВАРА =====

@router.callback_query(F.data.startswith("product_edit:"))
async def product_edit_start(callback: CallbackQuery, state: FSMContext):
    """✏️ Начало редактирования товара"""
    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    is_admin = callback.from_user.id in settings.admin_ids

    # Проверяем менеджеров
    is_manager = False
    if not is_admin:
                from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(callback.from_user.id) for m in managers)

    if not is_admin and not is_manager:
        return

    # 🔐 ИЗВЛЕКАЕМ PRODUCT_ID: всегда последний элемент после :
    product_id = int(callback.data.split(":")[-1])
    logger.info(f"✏️ {'Manager' if is_manager else 'Admin'} {callback.from_user.id} editing product {product_id}")

    # Сохраняем ID товара в state
    await state.update_data(edit_product_id=product_id)
    await state.set_state(ProductEditStates.waiting_for_edit_action)

    # Получаем товар
    async with database.get_session() as session:
        result = await session.execute(select(Product).where(Product.id == product_id))
        product = result.scalar()

    if not product:
        await callback.answer("❌ Товар не найден", show_alert=True)
        return

    # Меню редактирования
    keyboard = InlineKeyboardBuilder()
    keyboard.row(InlineKeyboardButton(text="📝 Название", callback_data=f"edit_field:title:{product_id}"))
    keyboard.row(InlineKeyboardButton(text="💰 Цена (INR)", callback_data=f"edit_field:price:{product_id}"))
    keyboard.row(InlineKeyboardButton(text="📝 Описание", callback_data=f"edit_field:description:{product_id}"))
    keyboard.row(
        InlineKeyboardButton(text="✅ В наличии", callback_data=f"edit_field:in_stock:1:{product_id}") if product.in_stock else InlineKeyboardButton(text="❌ Нет в наличии", callback_data=f"edit_field:in_stock:0:{product_id}")
    )
    keyboard.row(InlineKeyboardButton(text="🗑 Удалить", callback_data=f"product_delete:{product_id}"))
    keyboard.row(InlineKeyboardButton(text="🔙 Назад", callback_data=f"product_view:{product_id}"))

    text = (
        f"✏️ <b>Редактирование товара #{product_id}</b>\n\n"
        f"📝 <b>Текущие данные:</b>\n"
        f"Название: <code>{product.title[:50]}...</code>\n"
        f"Цена: ₹{product.price_inr:,.0f}\n"
        f"Наличие: {'✅' if product.in_stock else '❌'}\n\n"
        f"Выберите что изменить:"
    )

    try:
        await callback.message.edit_text(
            text,
            reply_markup=keyboard.as_markup(),
            parse_mode="HTML",
        )
    except Exception as e:
        # Если edit_text не удался (сообщение без текста), отправляем новое
        await callback.message.answer(
            text,
            reply_markup=keyboard.as_markup(),
            parse_mode="HTML",
        )

    await callback.answer()


@router.callback_query(F.data.startswith("edit_field:"))
async def product_edit_field(callback: CallbackQuery, state: FSMContext):
    """✏️ Редактирование конкретного поля"""
    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    is_admin = callback.from_user.id in settings.admin_ids

    # Проверяем менеджеров
    is_manager = False
    if not is_admin:
                from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(callback.from_user.id) for m in managers)

    if not is_admin and not is_manager:
        return

    parts = callback.data.split(":")
    field = parts[1]
    # 🔐 ИЗВЛЕКАЕМ PRODUCT_ID: всегда последний элемент
    product_id = int(parts[-1])

    await state.update_data(edit_product_id=product_id)

    if field == "title":
        await state.set_state(ProductEditStates.waiting_for_title)
        await callback.message.edit_text(
            "📝 <b>Изменение названия</b>\n\n"
            "Отправьте новое название товара:",
            reply_markup=InlineKeyboardBuilder().button(text="❌ Отмена", callback_data=f"product_edit:{product_id}").as_markup(),
            parse_mode="HTML",
        )
    elif field == "price":
        await state.set_state(ProductEditStates.waiting_for_price)
        await callback.message.edit_text(
            "💰 <b>Изменение цены</b>\n\n"
            "Отправьте новую цену в INR (число):\n"
            "Пример: <code>2950</code>",
            reply_markup=InlineKeyboardBuilder().button(text="❌ Отмена", callback_data=f"product_edit:{product_id}").as_markup(),
            parse_mode="HTML",
        )
    elif field == "description":
        await state.set_state(ProductEditStates.waiting_for_description)
        await callback.message.edit_text(
            "📝 <b>Изменение описания</b>\n\n"
            "Отправьте новое описание:",
            reply_markup=InlineKeyboardBuilder().button(text="❌ Отмена", callback_data=f"product_edit:{product_id}").as_markup(),
            parse_mode="HTML",
        )
    elif field == "in_stock":
        # Переключить наличие
        # callback_data: edit_field:in_stock:1:{product_id}
        current_value = int(parts[2]) == 1  # 1 = в наличии, 0 = нет
        # product_id уже извлечён выше как parts[-1]

        async with database.get_session() as session:
            result = await session.execute(select(Product).where(Product.id == product_id))
            product = result.scalar()
            if product:
                product.in_stock = not current_value
                await session.commit()
                logger.info(f"✅ Product {product_id} in_stock set to {product.in_stock}")

        await callback.answer(f"✅ {'В наличии' if product.in_stock else 'Нет в наличии'}", show_alert=True)

        # 🔐 ОБНОВЛЯЕМ МЕНЮ (с обработкой ошибки)
        try:
            await product_edit_start(callback, state)
        except Exception as e:
            logger.warning(f"Failed to update edit menu: {e}")
            # Fallback: просто отвечаем что обновлено
            await callback.message.answer(
                f"✅ {'В наличии' if product.in_stock else 'Нет в наличии'}\n\n"
                f"Нажмите 'Назад' и снова 'Редактировать' чтобы продолжить.",
                reply_markup=InlineKeyboardBuilder().button(text="🔙 Назад", callback_data=f"product_view:{product_id}").as_markup()
            )

        return

    await callback.answer()


@router.message(ProductEditStates.waiting_for_title)
async def product_edit_title_save(message: Message, state: FSMContext):
    """💾 Сохранение нового названия"""
    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    is_admin = message.from_user.id in settings.admin_ids
    is_manager = False
    if not is_admin:
                from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(message.from_user.id) for m in managers)

    if not is_admin and not is_manager:
        await message.answer("❌ Доступ запрещён")
        return

    data = await state.get_data()
    product_id = data.get("edit_product_id")

    if not product_id:
        await message.answer("❌ Ошибка: товар не найден")
        await state.clear()
        return

    new_title = message.text.strip()[:200]

    async with database.get_session() as session:
        result = await session.execute(select(Product).where(Product.id == product_id))
        product = result.scalar()
        if product:
            product.title = new_title
            await session.commit()
            logger.info(f"✅ Product {product_id} title updated by {'manager' if is_manager else 'admin'}: {new_title[:50]}")

    await message.answer(f"✅ <b>Название обновлено!</b>\n\n<code>{new_title[:100]}</code>", parse_mode="HTML")
    await state.clear()

    # 🔐 ВОЗВРАТ: Показываем товар снова
    from app.bots.handlers.manager import send_product_card
    await send_product_card(message, product_id)


@router.message(ProductEditStates.waiting_for_price)
async def product_edit_price_save(message: Message, state: FSMContext):
    """💾 Сохранение новой цены"""
    # 🔐 ПРОВЕРКА ПРАВ: Админы или Менеджеры
    is_admin = message.from_user.id in settings.admin_ids
    is_manager = False
    if not is_admin:
                from app.db.repositories import ManagerRepository
        async with database.get_session() as session:
            repo = ManagerRepository(session)
            managers = await repo.get_all_active()
            is_manager = any(m.telegram_id == str(message.from_user.id) for m in managers)

    if not is_admin and not is_manager:
        await message.answer("❌ Доступ запрещён")
        return

    data = await state.get_data()
    product_id = data.get("edit_product_id")

    if not product_id:
        await message.answer("❌ Ошибка: товар не найден")
        await state.clear()
        return

    try:
        new_price = float(message.text.strip())
        if new_price <= 0:
            raise ValueError("Цена должна быть больше 0")
    except (ValueError, TypeError):
        await message.answer("❌ Неверный формат цены. Отправьте число.")
        return

    async with database.get_session() as session:
        result = await session.execute(select(Product).where(Product.id == product_id))
        product = result.scalar()
        if product:
            product.price_inr = new_price
            await session.commit()
            logger.info(f"✅ Product {product_id} price updated by {'manager' if is_manager else 'admin'} to: {new_price}")

    await message.answer(f"✅ <b>Цена обновлена!</b>\n\n💰 ₹{new_price:,.0f}", parse_mode="HTML")
    await state.clear()

    # 🔐 ВОЗВРАТ: Показываем товар снова
    from app.bots.handlers.manager import send_product_card
    await send_product_card(message, product_id)


